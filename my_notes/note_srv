# systemctl
	编写NAME.service配置文件, 并放置至 /etc/systemd/system 或者 /lib/systemd/system
	sudo systemctl daemon-reload    #重新加载service配置文件:
	sudo systemctl start NAME.service
	sudo systemctl stop NAME.service
	使用服务定时器任务：(以ntpdate时间同步为例)
		1) 创建服务: /etc/systemd/system/ntpdate-sync.service
			[Unit]
			Description=Force time sync via ntpdate
			After=network-online.target
			[Service]
			Type=oneshot
			ExecStart=/usr/sbin/ntpdate -u 192.168.101.100
		2) 创建定时器: /etc/systemd/system/ntpdate-sync.timer
			[Unit]
			Description=Run ntpdate sync periodically
			[Timer]
			OnBootSec=30
			OnUnitActiveSec=10min
			AccuracySec=1s
			[Install]
			WantedBy=timers.target
		3) 启动定时器服务：
			sudo systemctl enable --now ntpdate-sync.timer
			sudo systemctl list-timers ntpdate-sync.timer

# ftp
	//创建ftpusers用户组
	sudo groupadd ftpusers
	//创建一个用户并且自动创建家目录为/home/ftpuser_lxr
	sudo useradd -m ftpuser_lxr
	//将这个新用户加入到ftpuserers用户组中
	usermod -G ftpusers ftpuser
	//更改密码
	sudo passwd ftpuser
	//为用户添加一个具有一定权限的文件夹
	mkdir /home/ftpuser_lxr/ftp
	//新建一个pub目录用于存放文件，并且赋予全部权限
	chmod 777 -R /home/ftpuser_lxr/ftp
	//限制用户登录方式；限制用户username只能通过ftp登陆，而不能直接登陆服务器
	usermod -s /sbin/nologin ftpuser

